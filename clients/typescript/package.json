{
  "name": "@multidelegator/client",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts",
    "clean": "rm -rf dist && rm -rf src/generated",
    "format": "biome check --write",
    "format:check": "biome check",
    "lint": "biome lint --write",
    "lint:check": "biome lint",
    "docs": "npx typedoc"
  },
  "dependencies": {
    "@solana/kit": "latest",
    "@solana/web3.js": "^1.98.4",
    "gill": "^0.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@solana-program/system": "latest",
    "@solana-program/token": "latest",
    "@sqds/multisig": "^2.1.4",
    "@swig-wallet/kit": "^1.5.0",
    "@types/node": "^25.0.10",
    "tsup": "^8.3.0",
    "tweetnacl": "^1.0.3",

    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
